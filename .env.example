# Claudio 环境变量模板
# 复制此文件为 .env 并填入实际值

# 网易云音乐 API 地址（本地部署后默认此地址）
NCM_API=http://localhost:3001

# OpenWeather API Key — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here

# Fish Audio TTS API Key — https://fish.audio/
FISH_AUDIO_API_KEY=your_key_here

# 飞书开放平台 — https://open.feishu.cn/app
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# UPnP 设备配置（JSON数组）
UPNP_DEVICES=[]

# 服务端口（可选，默认 3000）
PORT=3000

# 数据库路径（可选，默认 state.db）
DB_PATH=state.db

# 用户语料目录（可选，默认 user）
USER_CORPUS_DIR=user
